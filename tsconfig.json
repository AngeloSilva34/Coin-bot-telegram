{
    "compilerOptions": {
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "rootDir": "src",
        "outDir": "build"
    },
    "include": ["src", "src/app.ts"],
    "exclude": ["node_modules"]
}